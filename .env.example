# ─────────────────────────────────────────
# BASE DE DATOS
# ─────────────────────────────────────────
DATABASE_URL="postgresql://ganaderia:ganaderia_dev@localhost:5432/ganaderia_ph"

# Producción
POSTGRES_USER=ganaderia
POSTGRES_PASSWORD=CAMBIAR_EN_PRODUCCION
POSTGRES_DB=ganaderia_ph

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CAMBIAR_POR_SECRET_SEGURO_ACCESS
JWT_REFRESH_SECRET=CAMBIAR_POR_SECRET_SEGURO_REFRESH

# ─────────────────────────────────────────
# API
# ─────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────
# FRONTEND
# ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api

